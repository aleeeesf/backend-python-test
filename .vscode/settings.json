{
    "python.defaultInterpreterPath": "${workspaceFolder}/app/.venv/bin/python",
    "python.analysis.extraPaths": [
        "${workspaceFolder}/app",
        "${workspaceFolder}/app/application",
        "${workspaceFolder}/app/domain",
        "${workspaceFolder}/app/infrastructure",
        "${workspaceFolder}/app/core"
    ],
    "python.analysis.autoSearchPaths": false,
    "mypy-type-checker.args": [
        "--config-file=${workspaceFolder}/app/pyproject.toml"
    ],
    "mypy-type-checker.cwd": "${workspaceFolder}/app",
    "mypy-type-checker.importStrategy": "fromEnvironment",
}
